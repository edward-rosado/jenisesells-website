{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://real-estate-star.com/agent-content.schema.json",
  "title": "Agent Content",
  "description": "Content configuration for an agent's website sections. Read by agent-site at config/agents/{id}.content.json.",
  "type": "object",
  "required": ["template", "sections"],
  "additionalProperties": false,
  "properties": {
    "template": {
      "type": "string",
      "description": "Template identifier for the agent site layout",
      "examples": ["emerald-classic"]
    },
    "sections": {
      "type": "object",
      "required": ["hero", "stats", "services", "how_it_works", "sold_homes", "testimonials", "cma_form", "about", "city_pages"],
      "additionalProperties": false,
      "properties": {
        "hero": { "$ref": "#/$defs/section_hero" },
        "stats": { "$ref": "#/$defs/section_stats" },
        "services": { "$ref": "#/$defs/section_services" },
        "how_it_works": { "$ref": "#/$defs/section_how_it_works" },
        "sold_homes": { "$ref": "#/$defs/section_sold_homes" },
        "testimonials": { "$ref": "#/$defs/section_testimonials" },
        "cma_form": { "$ref": "#/$defs/section_cma_form" },
        "about": { "$ref": "#/$defs/section_about" },
        "city_pages": { "$ref": "#/$defs/section_city_pages" }
      }
    }
  },
  "$defs": {
    "section_hero": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["headline", "tagline", "cta_text", "cta_link"],
          "additionalProperties": false,
          "properties": {
            "headline": { "type": "string" },
            "tagline": { "type": "string" },
            "cta_text": { "type": "string" },
            "cta_link": { "type": "string" }
          }
        }
      }
    },
    "section_stats": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["items"],
          "additionalProperties": false,
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["value", "label"],
                "additionalProperties": false,
                "properties": {
                  "value": { "type": "string" },
                  "label": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "section_services": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["items"],
          "additionalProperties": false,
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["title", "description"],
                "additionalProperties": false,
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "section_how_it_works": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["steps"],
          "additionalProperties": false,
          "properties": {
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["number", "title", "description"],
                "additionalProperties": false,
                "properties": {
                  "number": { "type": "integer", "minimum": 1 },
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "section_sold_homes": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["items"],
          "additionalProperties": false,
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["address", "city", "state", "price"],
                "additionalProperties": false,
                "properties": {
                  "address": { "type": "string" },
                  "city": { "type": "string" },
                  "state": { "type": "string", "pattern": "^[A-Z]{2}$" },
                  "price": { "type": "string" },
                  "sold_date": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "section_testimonials": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["items"],
          "additionalProperties": false,
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["text", "reviewer", "rating"],
                "additionalProperties": false,
                "properties": {
                  "text": { "type": "string" },
                  "reviewer": { "type": "string" },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "source": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "section_cma_form": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["title", "subtitle"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" }
          }
        }
      }
    },
    "section_about": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["bio"],
          "additionalProperties": false,
          "properties": {
            "bio": { "type": "string" },
            "credentials": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "section_city_pages": {
      "type": "object",
      "required": ["enabled", "data"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "data": {
          "type": "object",
          "required": ["cities"],
          "additionalProperties": false,
          "properties": {
            "cities": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["slug", "city", "state", "county", "highlights", "market_snapshot"],
                "additionalProperties": false,
                "properties": {
                  "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                  "city": { "type": "string" },
                  "state": { "type": "string", "pattern": "^[A-Z]{2}$" },
                  "county": { "type": "string" },
                  "highlights": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "market_snapshot": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
