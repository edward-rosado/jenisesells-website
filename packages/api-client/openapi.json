  "components": {
    "schemas": {
      "BuyerDetailsRequest": {
        "required": [
          "desiredArea"
        ],
        "type": "object",
        "properties": {
          "desiredArea": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "minPrice": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "maxPrice": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "minBeds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "minBaths": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "preApproved": {
            "type": [
              "null",
              "string"
            ]
          },
          "preApprovalAmount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "profileUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "DeleteLeadDataRequest": {
        "required": [
          "email",
          "token",
          "reason"
        ],
        "type": "object",
        "properties": {
          "email": {
            "maxLength": 254,
            "minLength": 0,
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "FormEvent": {
        "enum": [
          "Viewed",
          "Started",
          "Submitted",
          "Succeeded",
          "Failed",
          null
        ]
      },
      "LeadType": {
        "enum": [
          "Buyer",
          "Seller",
          "Both"
        ]
      },
      "MarketingConsentRequest": {
        "required": [
          "optedIn",
          "consentText",
          "channels"
        ],
        "type": "object",
        "properties": {
          "optedIn": {
            "type": "boolean"
          },
          "consentText": {
            "type": "string"
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "OptOutRequest": {
        "required": [
          "email",
          "token"
        ],
        "type": "object",
        "properties": {
          "email": {
            "maxLength": 254,
            "minLength": 0,
            "type": "string"
          },
          "token": {
            "maxLength": 128,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "PostChatRequest": {
        "required": [
          "message"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "RecordTelemetryRequest": {
        "required": [
          "event",
          "agentId"
        ],
        "type": "object",
        "properties": {
          "event": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FormEvent"
              }
            ]
          },
          "agentId": {
            "minLength": 1,
            "type": [
              "null",
              "string"
            ]
          },
          "errorType": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RequestDeletionRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "maxLength": 254,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "SellerDetailsRequest": {
        "required": [
          "address",
          "city",
          "state",
          "zip"
        ],
        "type": "object",
        "properties": {
          "address": {
            "maxLength": 300,
            "minLength": 0,
            "type": "string"
          },
          "city": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "state": {
            "maxLength": 2,
            "minLength": 0,
            "type": "string"
          },
          "zip": {
            "pattern": "^\\d{5}(-\\d{4})?$",
            "type": "string"
          },
          "beds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "baths": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "sqft": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "SubmitLeadRequest": {
        "required": [
          "leadType",
          "firstName",
          "lastName",
          "email",
          "phone",
          "timeline",
          "marketingConsent"
        ],
        "type": "object",
        "properties": {
          "leadType": {
            "$ref": "#/components/schemas/LeadType"
          },
          "firstName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "lastName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "maxLength": 254,
            "minLength": 0,
            "type": "string"
          },
          "phone": {
            "maxLength": 30,
            "minLength": 0,
            "pattern": "^\\+?[\\d\\s\\-().]{7,20}$",
            "type": "string"
          },
          "timeline": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "buyer": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/BuyerDetailsRequest"
              }
            ]
          },
          "seller": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SellerDetailsRequest"
              }
            ]
          },
          "notes": {
            "maxLength": 2000,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "marketingConsent": {
            "$ref": "#/components/schemas/MarketingConsentRequest"
          }
        }
      },
      "SubscribeRequest": {
        "required": [
          "email",
          "token"
        ],
        "type": "object",
        "properties": {
          "email": {
            "maxLength": 254,
            "minLength": 0,
            "type": "string"
          },
          "token": {
            "maxLength": 128,
            "minLength": 0,
            "type": "string"
          }
        }
      }
    }
  },
