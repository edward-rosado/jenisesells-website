    <ProjectReference Include="../../RealEstateStar.Workers/Lead/RealEstateStar.Workers.Lead.CMA/RealEstateStar.Workers.Lead.CMA.csproj" />
    <ProjectReference Include="../../RealEstateStar.Workers/Lead/RealEstateStar.Workers.Lead.HomeSearch/RealEstateStar.Workers.Lead.HomeSearch.csproj" />
