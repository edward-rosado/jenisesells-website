    <ProjectReference Include="../../RealEstateStar.Api/RealEstateStar.Api.csproj" />
    <!-- Functions is a second composition root. ReferenceOutputAssembly=false prevents the
         Program class name collision with Api at compile time. The DLL is copied via a
         post-build target below so it lands in AppContext.BaseDirectory for runtime loading. -->
    <ProjectReference Include="../../RealEstateStar.Functions/RealEstateStar.Functions.csproj"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="../RealEstateStar.TestUtilities/RealEstateStar.TestUtilities.csproj" />
  </ItemGroup>
  <!-- Copy RealEstateStar.Functions.dll to the test output dir so architecture tests can load it.
       ReferenceOutputAssembly=false prevents the Program class name collision with Api, but also
       prevents the normal DLL copy — this target restores the copy step. -->
  <Target Name="CopyFunctionsDllToTestOutput" AfterTargets="Build">
    <PropertyGroup>
      <FunctionsDll>$(MSBuildThisFileDirectory)..\..\RealEstateStar.Functions\bin\$(Configuration)\net10.0\RealEstateStar.Functions.dll</FunctionsDll>
    </PropertyGroup>
    <Copy SourceFiles="$(FunctionsDll)"
          DestinationFolder="$(OutputPath)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(FunctionsDll)')" />
  </Target>
</Project>
