{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "real-estate-star-agents",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // CONTENT_KV stores published (live) and draft agent site content.
  // Key format: content:v1:{handle}:{locale}:{live|draft}
  // Provision with: wrangler kv namespace create CONTENT_KV
  // Then replace the placeholder IDs below with the values returned by that command.
  "kv_namespaces": [
    {
      "binding": "CONTENT_KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID",
      "preview_id": "REPLACE_WITH_KV_PREVIEW_NAMESPACE_ID"
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "real-estate-star-agents"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_API_URL": "https://api.real-estate-star.com",
    "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaSyCD8Lw5xaMCxoWEzkTRCT284Jv37AMfd2Y",
    "NEXT_PUBLIC_DEBUG": "true",
    "NEXT_PUBLIC_DEBUG_ACCOUNTS": "*"
  }
}
