# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production

# Required API Keys
ANTHROPIC_API_KEY=your_anthropic_key
ATTOM_API_KEY=your_attom_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_ID=your_stripe_price_id

# Platform Configuration
PLATFORM_BASE_URL=http://localhost:8080

# Optional: Cloudflare Site Deployment
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Turnstile (agent-site — NEXT_PUBLIC_ prefix required for Next.js client)
# Use 1x00000000000000000000AA for local dev (Cloudflare's always-pass test key)
# Set TURNSTILE_SITE_KEY in GitHub Secrets for production builds (workflow injects as NEXT_PUBLIC_TURNSTILE_SITE_KEY)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Optional: ScraperApi (for profile scraping fallback)
SCRAPER_API_KEY=

# CORS Origins
CORS_ORIGIN_1=http://localhost:3000
CORS_ORIGIN_2=http://localhost:3001
