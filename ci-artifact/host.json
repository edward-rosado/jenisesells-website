{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensions": {
    "durableTask": {
      "storageProvider": {
        "type": "AzureStorage"
      }
    },
    "queues": {
      "maxDequeueCount": 5,
      "visibilityTimeout": "00:05:00",
      "newBatchThreshold": 8,
      "batchSize": 16
    }
  }
}
